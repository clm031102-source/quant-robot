  "candidate_budget": {
    "first_batch_max_candidates": 120,
    "full_eval_top_candidates": 30,
    "pre_register_every_candidate": true,
    "record_rejected_candidates": true
  },
  "round_governance": {
    "round_unit": "factor_family_batch",
    "review_every_n_rounds": 3,
    "sync_every_n_rounds": 10,
    "three_round_review_required_actions": [
      "factor_family_result_audit",
      "reject_reason_histogram",
      "direction_adjustment_decision",
      "translation_layer_audit",
      "public_reference_method_review",
      "budget_waste_stop_loss_review"
    ],
    "ten_round_sync_required_actions": [
      "lightweight_stage_report",
      "factor_registry_or_research_ledger_update",
      "validation_command_rerun",
      "github_safe_sync_after_validation",
      "forbidden_data_and_secret_path_audit"
    ],
    "public_reference_projects": [
      "qlib",
      "alphalens",
      "vectorbt",
      "pyfolio",
      "worldquant_101_alphas"
    ],
    "profitability_guardrails": [
      "promotable_requires_cost_capacity_walk_forward_and_long_cycle_replay",
      "research_lead_requires_cross_period_ic_or_portfolio_evidence",
      "discard_single_family_after_repeated_same_blocker_failures",
      "do_not_optimize_for_raw_sharpe_before_hard_gates",
      "strong_ic_rejected_long_only_requires_gap_and_industry_neutral_audit_before_more_topn"
    ]
  },
  "universe_gate": {
    "exclude_st": true,
    "exclude_suspended": true,
    "exclude_limit_up_down_if_untradable": true,
    "min_listing_days": 120,
    "min_signal_date_amount": 10000000,
    "max_position_adv_participation": 0.05
  },
  "validation_windows": {
    "long_cycle_replay": {
      "start": "2015-01-01",
      "end": "2025-12-31",
      "purpose": "same-parameter replay and cycle/regime coverage audit before new mining claims"
    },
    "same_parameter_full_sample": {
      "start": "2015-01-01",
      "end": "2025-12-31",
      "purpose": "diagnostic full-sample rerun with frozen parameters; not promotion evidence by itself"
    },
    "discovery": {
      "start": "2023-07-03",
      "end": "2024-12-31",
      "purpose": "legacy candidate discovery only; short-window evidence must be replayed across long cycle before use"
    },
    "validation": {
      "start": "2025-01-01",
      "end": "2025-12-31",
      "purpose": "out-of-sample validation"
    },
    "final_holdout": {
      "start": "2026-01-01",
      "end": "2026-06-15",
      "purpose": "final recent holdout; do not tune after reading it"
    }
  },
  "promotion_gate": {
    "min_trades": 30,
    "min_abs_ic": 0.02,
    "min_abs_icir": 0.5,
    "min_positive_ic_rate": 0.55,
    "max_promotable_sharpe": 3.0,
    "min_walk_forward_accepted_folds": 2,
    "require_costs": true,
    "require_capacity_controls": true,
    "require_regime_review": true,
    "require_2026_holdout_not_collapsed": true
  },
  "safety": {
    "research_to_review_only": true,
    "broker_connection_allowed": false,
    "live_account_read_allowed": false,
    "order_placement_allowed": false,
    "automatic_live_trading_allowed": false,
    "push_requires_manual_approval": true
  }
